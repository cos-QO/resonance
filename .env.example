# Resonance — environment configuration
# Run ./setup.sh for a guided setup that fills this in automatically.
# .env is gitignored and never committed.

# ── Required ────────────────────────────────────────────────────────────────

# Linear personal API key
# Where: Linear → Settings → API → Personal API keys → Create key
# URL:   https://linear.app/settings/api
# Format: lin_api_...
LINEAR_API_KEY=

# Linear team UUID — the team whose issues Resonance will watch
# ./setup.sh will list your teams and let you pick by number.
# You can also paste a team URL and the wizard will resolve it automatically:
#   https://linear.app/your-workspace/team/RND/all  →  extracts RND → looks up UUID
LINEAR_TEAM_ID=

# ── Workflow state names ─────────────────────────────────────────────────────
#
# Set automatically by resonance setup. Override here only if you mapped
# Resonance roles to existing states during setup (e.g. no admin access).
# Defaults match the states setup creates when it has full permissions.
#
# LINEAR_STATE_ELIGIBILITY=Plan Approved       # you move issues here to authorize work
# LINEAR_STATE_IN_PROGRESS=In Progress         # set when agent starts
# LINEAR_STATE_FEEDBACK=Agent Feedback Needed  # set when agent needs human input
# LINEAR_STATE_REVIEW=Human Review             # set when agent finishes
# LINEAR_STATE_RETURN=Todo                     # set on failure or unsupported type

# ── Optional ────────────────────────────────────────────────────────────────

# Figma personal access token
# Only needed for design_to_code tasks (Figma designs → code).
# Where: Figma → Settings → Account → Personal access tokens
# URL:   https://www.figma.com/settings
# FIGMA_API_KEY=

# GitHub personal access token
# Only needed for automated PR creation (Milestone 3 — not required now).
# Where: GitHub → Settings → Developer settings → Personal access tokens
# URL:   https://github.com/settings/tokens
# Scopes needed: repo
# GITHUB_TOKEN=

# ── ConnectUI target repository ──────────────────────────────────────────────

# Absolute path to the connect-ui repo on this machine.
# When set, frontend/design task agents work inside this repo (git worktrees)
# rather than the agentic-pipeline repo — they can read and edit real platform code.
# CONNECT_UI_PATH=/path/to/connect-ui
