# Resonance — environment configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# ── Required ────────────────────────────────────────────────────────────────

# Linear personal API key
# Get it at: Linear → Settings → API → Personal API keys
LINEAR_API_KEY=lin_api_

# Linear project ID — the project Resonance will manage
# Find it in the project URL: linear.app/your-workspace/project/<id>/overview
# Or run: qo setup  (it will list your projects)
LINEAR_PROJECT_ID=

# ── Optional ────────────────────────────────────────────────────────────────

# Figma personal access token
# Required only for design_to_code task type
# Get it at: Figma → Settings → Account → Personal access tokens
# FIGMA_API_KEY=

# GitHub personal access token
# Required for automated PR creation (Milestone 3)
# Scopes needed: repo
# Get it at: GitHub → Settings → Developer settings → Personal access tokens
# GITHUB_TOKEN=
