{
  "SessionStart": [
    {
      "matcher": "startup|resume",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_DIR}/hooks/session-context.py\"",
          "timeout": 3
        }
      ]
    }
  ],
  "PreToolUse": [
    {
      "matcher": "Agent:security|Agent:.*security.*",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_DIR}/hooks/online-security-research.py\" PreToolUse Agent",
          "timeout": 5
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "TodoWrite",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_DIR}/hooks/todo-sync.py\"",
          "timeout": 5
        }
      ]
    },
    {
      "matcher": "Write|Edit|MultiEdit",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_DIR}/hooks/folder-structure-enforcer.py\"",
          "timeout": 3
        }
      ]
    }
  ],
  "SubagentStart": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_DIR}/hooks/execution-tracker.py\"",
          "timeout": 3
        }
      ]
    }
  ],
  "SubagentStop": [
    {
      "matcher": "pm",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_DIR}/hooks/validate-pm-output.py\"",
          "timeout": 3
        }
      ]
    },
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_DIR}/hooks/execution-tracker.py\"",
          "timeout": 3
        }
      ]
    }
  ],
  "PostToolUseFailure": [
    {
      "matcher": "Bash|Write|Edit|Agent",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_DIR}/hooks/error-tracker.py\"",
          "timeout": 3
        }
      ]
    }
  ],
  "Stop": [
    {
      "hooks": [
        {
          "type": "agent",
          "prompt": "You are a completion verifier. Check if the work just done is consistent and complete.\n\n1. Read /.claude/memory/active/execution-tracker.json (if it exists)\n   - Are there phases marked in-progress that should be completed?\n   - Are handoff_files populated for completed phases?\n2. Check git status — are there uncommitted changes that should have been committed?\n3. If a TODO file is referenced in the tracker, verify task checkboxes match phase status.\n\nRespond with {\"ok\": true} if everything is consistent, or {\"ok\": false, \"reason\": \"...\"} if something needs attention.\n\nBe lenient — only flag real inconsistencies, not stylistic issues. If no tracker exists, respond ok.",
          "model": "haiku",
          "timeout": 30
        }
      ]
    }
  ],
  "PreCompact": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_DIR}/hooks/unified-context-processor.py\" checkpoint",
          "timeout": 5
        }
      ]
    }
  ]
}
