# ── Credentials ───────────────────────────────────────────────────────────────
# Never commit .env — use .env.example as the template
.env
.env.*
!.env.example

# ── Resonance runtime ─────────────────────────────────────────────────────────
# Everything created when the orchestrator runs — state, logs, worktrees
runs/
workspaces/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# ── Claude Code — personal developer setup, not part of the project ──────────
# .claude/ is the local Claude Code multi-agent config (agents, skills, hooks).
# .mcp.json configures local MCP servers with machine-specific paths.
# Both belong to the developer's environment, not the repo.
.claude/
.mcp.json

# ── OS & editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~
