# ── Credentials ───────────────────────────────────────────────────────────────
# Never commit .env — use .env.example as the template
.env
.env.*
!.env.example

# ── Resonance runtime ─────────────────────────────────────────────────────────
# Everything created when the orchestrator runs — state, logs, worktrees
runs/
workspaces/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# ── Claude Code — local config & project-specific memory ─────────────────────
# MCP config has local paths — each user has their own
.mcp.json

# Project memory is session-specific; standards/ and templates/ are committed
.claude/memory/active/
.claude/memory/compound/
.claude/memory/discovery/
.claude/memory/handoffs/
.claude/memory/plans/
.claude/memory/procedures/
.claude/memory/project/
.claude/memory/reports/
.claude/memory/session_checkpoints/
.claude/memory/telemetry/
.claude/memory/todos/
.claude/memory/watchdog/
.claude/memory/git-commits.md

# Agent memory is personal to each developer's session
.claude/agent-memory/

# Lock files and temp dirs created during sessions
.claude/hooks/*.lock
.claude/temp/
.claude/memory/temp/

# Hook and script bytecode
.claude/**/__pycache__/
.claude/**/*.pyc
.claude/**/*.pyo

# ── OS & editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~
